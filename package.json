{
  "name": "collectium-slack-connector",
  "version": "1.0.0",
  "description": "Production-grade Slack MCP connector for Collectium",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "dev": "ts-node-dev --respawn --transpile-only index.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only worker.ts",
    "lint": "eslint 'src/**/*.ts' --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "migrate": "supabase db push"
  },
  "dependencies": {
    "@slack/web-api": "^7.3.4",
    "@supabase/supabase-js": "^2.44.2",
    "bullmq": "^5.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.57.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}