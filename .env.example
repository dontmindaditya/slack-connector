

# ─── Server ──────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000

# Public base URL of this service (used for OAuth redirects and install success URLs)
APP_BASE_URL=https://your-domain.com

# ─── Slack App Credentials ───────────────────────────────────────────────────
# Get these from https://api.slack.com/apps → your app → Basic Information

SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_SIGNING_SECRET=your-slack-signing-secret

# OAuth redirect URI — must match exactly what you registered in Slack app settings
# Format: https://<your-domain>/api/v1/slack/auth/callback
SLACK_REDIRECT_URI=https://your-domain.com/api/v1/slack/auth/callback

# Bot scopes requested during OAuth install (comma-separated, no spaces)
SLACK_BOT_SCOPES=channels:read,channels:history,groups:read,groups:history,chat:write,users:read,team:read,im:read,mpim:read

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get from Supabase dashboard → Project Settings → API

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Redis (BullMQ) ───────────────────────────────────────────────────────────
# Local: 127.0.0.1:6379
# Production: Use Redis Cloud, Upstash, or AWS ElastiCache

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Collectium Internal API ──────────────────────────────────────────────────
# Minimum 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

COLLECTIUM_API_KEY=your-minimum-32-character-api-key-here

# ─── Optional: Token Encryption ───────────────────────────────────────────────
# Encrypts Slack bot tokens at rest in Supabase.
# Must be exactly 64 hex characters (32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Leave empty to skip encryption (not recommended for production).

TOKEN_ENCRYPTION_KEY=
